---
// src/pages/index.astro

// ⚠️ PENTING: GANTI DENGAN ID SPREADSHEET ANDA SENDIRI
const SHEET_ID = "1ympvFoFimGJo7mzfrVVefHvl0cCM7TJs_TUf285ajEo"; 
const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv`;

// Mengambil data dari Google Sheets saat website di-build
const response = await fetch(CSV_URL);
const csvText = await response.text();

function parseCSV(csv) {
  // Memisahkan baris dengan aman baik untuk Windows maupun Linux
  const lines = csv.split(/\r?\n/);
  if (lines.length === 0 || lines[0] === "") return [];
  
  // Membaca header dan membersihkan tanda kutip bawaan Google
  const headers = lines[0].split(',').map(h => h.replace(/"/g, '').trim());
  
  return lines.slice(1).map(line => {
    // Trik aman memisahkan kolom csv yang dibungkus tanda kutip oleh Google
    const matches = line.match(/(".*?"|[^",\s]+)(?=\s*,|\s*$|\s*\n)/g) || line.split(',');
    let obj = {};
    headers.forEach((header, i) => {
      let val = matches[i] ? matches[i].replace(/"/g, '').trim() : "";
      obj[header] = val;
    });
    return obj;
  }).filter(item => item.judul && item.judul !== "judul");
}

const semuaBerita = parseCSV(csvText);

// Memisahkan berita utama (breaking) dan berita lainnya
const beritaUtama = semuaBerita[0];
const beritaReguler = semuaBerita.slice(1);
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
<link rel="stylesheet" href="/src/styles/global.css">

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ VIBE NEWS — Info Viral Terkini</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-[#0b0f19] text-slate-200 antialiased selection:bg-cyan-500 selection:text-black">
<body class="bg-slate-950 text-white">


    <!-- Top Glow Effect -->
