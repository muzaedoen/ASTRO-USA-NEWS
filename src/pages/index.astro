        <div class="max-w-6xl mx-auto px-4 h-16 flex justify-between items-center">
            <a href="#" class="text-xl font-black tracking-tighter bg-gradient-to-r from-cyan-400 via-sky-400 to-purple-500 bg-clip-text text-transparent">
                ⚡ VIBE<span class="text-white font-light">NEWS</span>
            </a>
            <div class="flex items-center gap-4">
                <span class="flex h-2 w-2 relative">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
                </span>
                <span class="text-xs font-semibold text-cyan-400 tracking-wider uppercase bg-cyan-500/10 px-3 py-1 rounded-full border border-cyan-500/20">
                    Live Database
                </span>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8 relative">

        <!-- 💰 SLOT IKLAN ADSTERRA 1 (Atas Halaman / Banner 728x90) -->
        <div class="w-full flex justify-center mb-10 overflow-hidden min-h-[90px] bg-slate-900/40 rounded-xl border border-slate-800 p-2 text-center items-center">
            <div class="w-full text-center">
                <!-- SCRIPT BANNER ADSTERRA (Ganti kode div & script di bawah dengan kode dari Dashboard Adsterra Anda) -->
                <div id="container-adsterra-banner-top">
                    <span class="text-xs text-slate-500 block mb-1 tracking-widest uppercase font-mono">Advertisement</span>
                    <script type="text/javascript">
                        atOptions = {
                            'key' : 'MASUKKAN_KEY_BANNER_ADSTERRA_ANDA_DI_SINI',
                            'format' : 'iframe',
                            'height' : 90,
                            'width' : 728,
                            'params' : {}
                        };
                    </script>
                    <script type="text/javascript" src="//www.highperformanceformat.com/MASUKKAN_KEY_BANNER_ADSTERRA_ANDA_DI_SINI/invoke.js"></script>
                </div>
            </div>
        </div>

        {semuaBerita.length > 0 ? (
            <!-- Layout Grid Asimetris Modern -->
            <div class="space-y-12">
                
                {/* 1. SECTION BERITA UTAMA (HERO) */}
                {beritaUtama && (
                    <section class="group relative bg-slate-900/40 border border-slate-800 rounded-3xl overflow-hidden hover:border-slate-700/60 transition-all duration-300">
                        <div class="grid lg:grid-cols-12 gap-0">
                            <div class="lg:col-span-7 aspect-video lg:aspect-auto lg:h-[450px] overflow-hidden relative">
                                <div class="absolute inset-0 bg-gradient-to-t from-[#0b0f19] via-transparent to-transparent z-10 lg:hidden"></div>
                                <img 
                                    src={beritaUtama.gambar || "https://images.unsplash.com/photo-1504711434969-e33886168f5c?q=80&w=1200"} 
                                    alt={beritaUtama.judul}
                                    class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700 ease-out"
                                />
                            </div>
                            <div class="lg:col-span-5 p-6 lg:p-10 flex flex-col justify-center z-20">
                                <span class="text-xs font-bold text-cyan-400 tracking-widest uppercase mb-3 block">
                                    🚀 {beritaUtama.tanggal || "Trending Utama"}
                                </span>
                                <h2 class="text-2xl lg:text-3xl font-extrabold text-white tracking-tight leading-tight mb-4 group-hover:text-cyan-400 transition-colors">
                                    {beritaUtama.judul}
                                </h2>
                                <p class="text-slate-400 text-sm leading-relaxed mb-6 line-clamp-4">
                                    {beritaUtama.konten}
                                </p>
                                <a href="#" class="inline-flex items-center gap-2 bg-white text-black font-semibold text-sm px-6 py-3 rounded-xl hover:bg-cyan-400 hover:text-black transition-colors w-fit shadow-lg shadow-white/5">
                                    Baca Selengkapnya
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                                </a>
                            </div>
                        </div>
                    </section>
                )}

                {/* 2. GRID BERITA REGULER */}
                <section class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {beritaReguler.map((berita, index) => (
                        <article class="bg-slate-900/20 border border-slate-800/80 rounded-2xl overflow-hidden hover:border-slate-700 hover:bg-slate-900/40 transition-all duration-300 flex flex-col group">
                            <div class="aspect-video overflow-hidden bg-slate-900 relative">
                                <img 
                                    src={berita.gambar || "https://images.unsplash.com/photo-1504711434969-e33886168f5c?q=80&w=600"} 
                                    alt={berita.judul}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                                />
                            </div>
                            <div class="p-5 flex-1 flex flex-col justify-between">
                                <div>
                                    <span class="text-[10px] font-bold text-purple-400 tracking-widest uppercase mb-2 block">
                                        ⏱️ {berita.tanggal || "Baru"}
                                    </span>
                                    <h3 class="text-base font-bold text-white tracking-tight leading-snug line-clamp-2 group-hover:text-cyan-400 transition-colors mb-2">
                                        {berita.judul}
                                    </h3>
                                    <p class="text-slate-400 text-xs leading-relaxed line-clamp-3 mb-4">
                                        {berita.konten}
                                    </p>
                                </div>
                                <a href="#" class="text-xs font-semibold text-slate-300 group-hover:text-cyan-400 transition-colors flex items-center gap-1.5 pt-2 mt-auto border-t border-slate-800/60">
                                    Buka Artikel
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                                </a>
                            </div>
                        </article>
                    ))}
                </section>
            </div>
        ) : (
            <div class="text-center py-24 bg-slate-900/20 border border-dashed border-slate-800 rounded-3xl">
                <div class="w-12 h-12 rounded-full bg-cyan-500/10 border border-cyan-500/30 flex items-center justify-center mx-auto mb-4 animate-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-cyan-400"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-1.5 3h1.5m-7.5-3h7.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.75c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18V6.125c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124M12 7.5a3.75 3.75 0 100-7.5 3.75 3.75 0 000 7.5z" /></svg>
                </div>
