---
// Kita kembalikan ke mode statis agar build Cloudflare sukses 100%
export const prerender = true;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>USA NEWS - Realtime Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <style>
      body {
        background-color: #0a0f1d !important;
        color: #e2e8f0 !important;
        font-family: 'Segoe UI', Roboto, sans-serif;
      }
      .premium-card {
        background-color: #131c31;
        border: 1px solid #1e293b;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0, 242, 254, 0.08);
        margin-bottom: 28px;
      }
      .neon-text {
        color: #00f2fe;
        text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
      }
      .premium-btn {
        background: linear-gradient(135deg, #00f2fe 0%, #0072ff 100%);
        border: none;
        color: #0a0f1d !important;
        font-weight: 700;
        border-radius: 12px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
      }
      .ad-container {
        margin: 20px 0;
        min-height: 50px;
        text-align: center;
        display: flex;
        justify-content: center;
        align-items: center;
      }
    </style>
  </head>
  <body>

    <nav class="navbar border-bottom py-3" style="background-color: #0d1527; border-color: #1e293b !important;">
      <div class="container justify-content-center" style="max-width: 450px;">
        <span class="navbar-brand mb-0 h1 text-white fw-bold m-0" style="font-size: 20px; letter-spacing: 1px;">
          ⚡ VIBE<span class="neon-text">NEWS</span>
        </span>
      </div>
    </nav>

    <div class="container my-4" style="max-width: 450px;">
      
      <div class="ad-container">
        <div style="color: #64748b; font-size: 12px; border: 1px dashed #1e293b; padding: 10px; width: 100%;">[Iklan Adsterra Banner 1]</div>
      </div>

      <div id="news-list">
        <div class="text-center my-5 text-muted" id="loading-spinner">
          <p>⏳ Memuat berita terbaru langsung dari spreadsheet...</p>
        </div>
      </div>

    </div>

    <footer class="text-center py-4" style="font-size: 11px; color: #64748b; border-top: 1px solid #131c31; background-color: #0d1527;">
      <p class="m-0">© 2026 USA News</p>
    </footer>

    <script is:inline>
      const sheetId = '1ympvFoFimGJo7mzfrVVefHvl0cCM7TJs_TUf285ajEo'; 
      const sheetName = 'wbu'; 
      const linkAPI = `https://docs.google.com/spreadsheets/d/${sheetId}/gviz/tq?tqx=out:json&sheet=${sheetName}`;

      async function fetchSheetsLive() {
        const targetContainer = document.getElementById('news-list');
        try {
          const res = await fetch(linkAPI);
          const rawText = await res.text();
          
          // Parsing struktur data JSON gviz dari Google Sheets
          const cleanJson = JSON.parse(rawText.substring(47).slice(0, -2));
          const rows = cleanJson.table.rows;
          
          let cardsHtml = '';
          
          rows.forEach((row, index) => {
            const title = row.c[0] ? row.c[0].v : "Untitled";
            const date = row.c[1] ? row.c[1].v : "12 Juni 2026";
            const desc = row.c[2] ? row.c[2].v : "No Description";
            const img = row.c[3] ? row.c[3].v : "https://images.unsplash.com/photo-1540910419892-4a36d2c3266c?auto=format&fit=crop&w=800&q=80";
            const destinationUrl = row.c[4] ? row.c[4].v : "#";

            cardsHtml += `
              <div class="premium-card">
                <div style="position: relative; height: 230px; background-color: #0a0f1d;">
                  <img src="${img}" alt="${title}" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;" />
                </div>
                <div class="p-4">
                  <div class="mb-2 d-flex align-items-center" style="font-size: 13px; color: #94a3b8; gap: 6px;">
                    <span>🚀 ${date}</span>
                  </div>
                  <h2 class="h4 text-white fw-bold mb-3" style="line-height: 1.4;">${title}</h2>
                  <p style="font-size: 14px; color: #94a3b8; line-height: 1.6; margin-bottom: 28px;">${desc}</p>
                  <a href="${destinationUrl}" target="_blank" rel="noopener noreferrer" class="premium-btn">
                    <span>Baca Selengkapnya</span>
                  </a>
                </div>
              </div>
            `;

            if (index === 0) {
              cardsHtml += `
                <div class="ad-container">
                  <div style="color: #64748b; font-size: 12px; border: 1px dashed #1e293b; padding: 10px; width: 100%;">[Iklan Adsterra Banner 2]</div>
                </div>
              `;
            }
          });

          targetContainer.innerHTML = cardsHtml;
        } catch (err) {
          targetContainer.innerHTML = '<p class="text-center text-danger">Gagal memuat berita. Pastikan setelan Google Sheets sudah "Anyone with the link".</p>';
        }
      }

      // Jalankan fungsi setelah browser selesai memuat dokumen HTML
      window.addEventListener('DOMContentLoaded', fetchSheetsLive);
    </script>
  </body>
</html>
