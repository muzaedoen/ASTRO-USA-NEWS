---
// URL Web App Google Apps Script Anda (Sudah otomatis terpasang dengan benar)
const linkAPI = 'https://script.google.com/macros/s/AKfycbzE47FzY6H-OOfz_5f8UjN9F9mREu1XkYwU_D4pfeBqZp8yO9aR_7i_uYshBWhg_5x/exec';

let listBerita = [];

try {
  const response = await fetch(linkAPI);
  listBerita = await response.json();
} catch (e) {
  // Pengaman cadangan: Jika koneksi internet putus, web tidak akan eror merah di Termux
  listBerita = [
    {
      title: "Kematian Trump",
      date: "11 Juni 2026",
      description: "Ini adalah uji coba konten berita pertama yang berhasil ditarik langsung dari database Google Sheets secara realtime.",
      image: "https://images.unsplash.com/photo-1540910419892-4a36d2c3266c?auto=format&fit=crop&w=800&q=80"
    }
  ];
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VIBENEWS - Premium Live Dashboard</title>
    
    <!-- Bootstrap CSS murni untuk layout premium instant -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <style>
      /* STYLE PREMIUM: DIJAMIN HITAM PEKAT & NEON CYAN */
      body {
        background-color: #0a0f1d !important;
        color: #e2e8f0 !important;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      .premium-card {
        background-color: #131c31;
        border: 1px solid #1e293b;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0, 242, 254, 0.08);
        margin-bottom: 28px;
      }
      .neon-text {
        color: #00f2fe;
        text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
      }
      .premium-btn {
        background: linear-gradient(135deg, #00f2fe 0%, #0072ff 100%);
        border: none;
        color: #0a0f1d !important;
        font-weight: 700;
        border-radius: 12px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
      }
      .badge-live {
        background-color: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.2);
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 600;
      }
    </style>
  </head>
  <body>

    <!-- NAVBAR HEADER -->
    <nav class="navbar border-bottom py-3" style="background-color: #0d1527; border-color: #1e293b !important;">
      <div class="container justify-content-between" style="max-width: 450px;">
        <span class="navbar-brand mb-0 h1 text-white fw-bold m-0" style="font-size: 20px; letter-spacing: 1px;">
          ⚡ VIBE<span class="neon-text">NEWS</span>
        </span>
        <span class="badge-live">● LIVE DATABASE</span>
      </div>
    </nav>

    <!-- CONTAINER UTAMA (OTOMATIS LOOPING SEBANYAK DATA DI SPREADSHEET) -->
    <div class="container my-4" style="max-width: 450px;">
      
      {listBerita.map((berita) => (
        <div class="premium-card">
          
          <!-- BAGIAN GAMBAR BERITA -->
          <div style="position: relative; height: 230px; background-color: #0a0f1d;">
            <img 
              src={berita.image || "https://images.unsplash.com/photo-1540910419892-4a36d2c3266c?auto=format&fit=crop&w=800&q=80"} 
              alt={berita.title} 
              style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;"
            />
            <span style="position: absolute; top: 12px; left: 12px; background: rgba(10,15,29,0.85); color: #94a3b8; font-size: 10px; padding: 4px 10px; border-radius: 6px; font-weight: 600; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.05);">
              Advertisement
            </span>
          </div>

          <!-- DETAIL TEKS BERITA -->
          <div class="p-4">
            <div class="mb-2 d-flex align-items-center" style="font-size: 13px; color: #94a3b8; gap: 6px;">
              <span>🚀 {berita.date || "11 Juni 2026"}</span>
            </div>
            
            <h2 class="h4 text-white fw-bold mb-3" style="line-height: 1.4;">
              {berita.title}
            </h2>
            
            <p style="font-size: 14px; color: #94a3b8; line-height: 1.6; margin-bottom: 28px;">
              {berita.description}
            </p>

            <!-- TOMBOL BACA + IKON PANAH (UKURAN DI-LOCK 16PX) -->
            <a href="#" class="premium-btn">
              <span>Baca Selengkapnya</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

        </div>
      ))}

    </div>

    <!-- FOOTER -->
    <footer class="text-center py-4" style="font-size: 11px; color: #64748b; border-top: 1px solid #131c31; background-color: #0d1527;">
      <p class="m-0">© 2026 VibeNews Premium • Ditenagai oleh Astro & Sheets</p>
    </footer>

  </body>
</html>
