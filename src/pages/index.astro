        <!-- 💰 SLOT IKLAN ADSTERRA 2 (Bawah Halaman / Banner 468x60 atau Native) -->
        <div class="w-full flex justify-center mt-16 overflow-hidden min-h-[60px] bg-slate-900/40 rounded-xl border border-slate-800 p-2 text-center items-center">
            <div class="w-full text-center">
                <span class="text-xs text-slate-500 block mb-1 tracking-widest uppercase font-mono">Sponsored</span>
