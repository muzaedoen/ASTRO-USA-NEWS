---
// Jika ada import data Google Sheets Anda, biarkan tetap di paling atas sini
// Contoh: const data = await fetch('1ympvFoFimGJo7mzfrVVefHvl0cCM7TJs_TUf285ajEo').then(res => res.json());

// Data dummy untuk tes visual (Nanti otomatis terganti dengan data Google Sheets Anda)
const berita = {
  title: "Kematian Trump",
  date: "11 Juni 2026",
  description: "Ini adalah uji coba konten berita pertama yang berhasil ditarik langsung dari database Google Sheets secara realtime.",
  image: "https://images.unsplash.com/photo-1540910419892-4a36d2c3266c?auto=format&fit=crop&w=800&q=80"
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VIBENEWS - Live Database</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              neonCyan: '#00f2fe',
              darkBg: '#0a0f1d'
            }
          }
        }
      }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
  </head>
  
  <body class="bg-[#0a0f1d] text-slate-200 min-h-screen flex flex-col justify-between selection:bg-cyan-500 selection:text-black">
    
    <header class="border-b border-slate-800 bg-[#0d1527]/80 backdrop-blur-md sticky top-0 z-50 px-4 py-3">
      <div class="max-w-md mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold tracking-wider text-white">⚡ VIBE<span class="text-[#00f2fe]">NEWS</span></span>
        </div>
        <div class="flex items-center gap-1.5 bg-emerald-950/50 border border-emerald-500/30 px-2.5 py-1 rounded-full">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[10px] font-semibold text-emerald-400 uppercase tracking-wider">Live Database</span>
        </div>
      </div>
    </header>

    <main class="flex-grow p-4 flex flex-col justify-center items-center">
      <div class="w-full max-w-md bg-[#131c31] border border-slate-800 rounded-2xl overflow-hidden shadow-2xl shadow-cyan-950/20 transition-all duration-300 hover:border-cyan-500/40">
        
        <div class="relative h-48 w-full bg-slate-900 overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-t from-[#131c31] via-transparent to-transparent z-10"></div>
          <span class="absolute top-3 left-3 bg-[#0a0f1d]/80 backdrop-blur-md text-[#00f2fe] text-[10px] font-bold px-2.5 py-1 rounded-md border border-cyan-500/20 z-20 uppercase tracking-wider">
            Advertisement
          </span>
          <img 
            src={berita.image} 
            alt={berita.title}
            class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-500"
          />
        </div>

        <div class="p-5">
          <div class="flex items-center gap-2 text-xs text-slate-400 mb-2">
            <span>🚀 {berita.date}</span>
          </div>
          
          <h1 class="text-xl font-bold text-white mb-3 tracking-tight leading-snug hover:text-[#00f2fe] transition-colors">
            {berita.title}
          </h1>
          
          <p class="text-sm text-slate-400 leading-relaxed mb-5">
            {berita.description}
          </p>

          <a 
            href="#" 
            class="inline-flex items-center justify-between w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-slate-950 text-sm font-bold py-3 px-4 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-cyan-500/20"
          >
            <span>Baca Selengkapnya</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

      </div>
    </main>

    <footer class="text-center py-4 border-t border-slate-900 text-[11px] text-slate-500">
      <p>© 2026 VibeNews Premium • Ditenagai oleh Astro & Sheets</p>
    </footer>

  </body>
</html>
