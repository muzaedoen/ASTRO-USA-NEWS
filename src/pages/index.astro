---
// Mengambil koneksi database D1 dari Cloudflare Workers
const db = Astro.locals.runtime?.env?.DB;

let namaWeb = "⚡ VIBENEWS";
let scriptIklan = "";
let daftarBerita = [];

if (db) {
  try {
    // 1. Ambil Konfigurasi Nama Web & Iklan
    const configRes = await db.prepare("SELECT * FROM konfigurasi").all();
    configRes.results.forEach((row) => {
      if (row.kunci === 'nama_web') namaWeb = row.nilai;
      if (row.kunci === 'script_iklan') scriptIklan = row.nilai;
    });

    // 2. Fitur Kejutan: Hitung & Filter Pengunjung Riil (Anti-Bot)
    const userAgent = Astro.request.headers.get('user-agent') || '';
    const ipAddress = Astro.request.headers.get('cf-connecting-ip') || '127.0.0.1';


    // Filter bot populer (Google, Bing, Yahoo, Uptime, dll)
    const isBot = /bot|googlebot|crawler|spider|robot|crawling|slurp|bingbot/i.test(userAgent);
    
    if (!isBot) {
      // Catat kunjungan jika manusia riil
      await db.prepare("INSERT INTO statistik_pengunjung (ip_address) VALUES (?)").bind(ipAddress).run();
    }

    // 3. Ambil Daftar Berita Terbaru
    const beritaRes = await db.prepare("SELECT * FROM berita ORDER BY id DESC").all();
    daftarBerita = beritaRes.results;
  } catch (err) {
    console.error("Gagal memuat database D1:", err);
  }
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{namaWeb} - Dashboard Berita</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <style>
      body {
        background-color: #0a0f1d !important;
        color: #e2e8f0 !important;
        font-family: 'Segoe UI', Roboto, sans-serif;
      }
      .premium-card {
        background-color: #131c31;
        border: 1px solid #1e293b;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0, 242, 254, 0.08);
        margin-bottom: 28px;
      }
      .neon-text {
        color: #00f2fe;
        text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
      }
      .premium-btn {
        background: linear-gradient(135deg, #00f2fe 0%, #0072ff 100%);
        border: none;
        color: #0a0f1d !important;
        font-weight: 700;
        border-radius: 12px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
      }
    </style>
  </head>
  <body>

    <nav class="navbar border-bottom py-3" style="background-color: #0d1527; border-color: #1e293b !important;">
      <div class="container justify-content-center" style="max-width: 450px;">
        <span class="navbar-brand mb-0 h1 text-white fw-bold m-0" style="font-size: 20px; letter-spacing: 1px;">
          {namaWeb}
        </span>
      </div>
    </nav>

    <div class="container my-4" style="max-width: 450px;">
      
      <div class="text-center my-3">
        <Fragment set:html={scriptIklan} />
      </div>

      {daftarBerita.length > 0 ? (
        daftarBerita.map((item) => (
          <div class="premium-card">
            <div style="position: relative; height: 230px; background-color: #0a0f1d;">
              <img src={item.gambar} alt={item.judul} style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;" />
            </div>
            <div class="p-4">
              <div class="mb-2" style="font-size: 13px; color: #94a3b8;">
                <span>🚀 {item.tanggal}</span>
              </div>
              <h2 class="h4 text-white fw-bold mb-3" style="line-height: 1.4;">{item.judul}</h2>
              <p style="font-size: 14px; color: #94a3b8; line-height: 1.6; margin-bottom: 28px;">{item.deskripsi}</p>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="premium-btn">
                <span>Baca Selengkapnya</span>
              </a>
            </div>
          </div>
        ))
      ) : (
        <div class="text-center my-5 text-muted">
          <p>Belum ada berita. Silakan isi lewat Halaman Admin.</p>
        </div>
      )}

    </div>

    <footer class="text-center py-4" style="font-size: 11px; color: #64748b; border-top: 1px solid #131c31; background-color: #0d1527;">
      <p class="m-0">© 2026 {namaWeb}</p>
    </footer>

  </body>
</html>
